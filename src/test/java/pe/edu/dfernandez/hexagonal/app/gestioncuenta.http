@baseUrl = http://localhost:8080/api

### Crear cuenta 1
POST {{baseUrl}}/cuentas
content-type: application/json

{
    "nombre": "Juan Perez",
    "saldo": 1000
}

### Crear cuenta 2
POST {{baseUrl}}/cuentas
content-type: application/json

{
    "nombre": "Carlos Lopez",
    "saldo": 150
}

### Listar todas las cuentas
GET {{baseUrl}}/cuentas
content-type: application/json

### Listar cuentas por saldo
GET {{baseUrl}}/cuentas/saldo
content-type: application/json

{
    "nombre": "Juan Perez"
}

### Listar cuentas por saldo
GET {{baseUrl}}/cuentas/saldo
content-type: application/json

{
    "nombre": "Carlos Lopez"
}

### Crear transacción 1
POST {{baseUrl}}/transacciones
content-type: application/json

{
    "cuenta_origen_id": 1,
    "cuenta_destino_id": 2,
    "monto": 50,
    "comision": 1.5,
    "tipo": "TRANSFERENCIA",
    "descripcion": "Pago de servicios"
}

